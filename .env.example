# Шаблон локальных env-переменных для сборочного pipeline.
#
# Использование:
#   cp .env.example .env.local
#   # отредактировать .env.local под себя
#
# scripts/build-deb.sh source'ит .env.local при наличии (см. начало скрипта).
# Сам .env.local в .gitignore — в репозиторий не попадает.

# ---- HTTP/HTTPS прокси для сборки ----------------------------------------
# Подхватывают: curl (Phase 0.5 AppImage runtime, Phase 1 ORT/vosk),
# cargo/git (download crates), gh CLI. Раскомментируй и подправь под себя.
#
# HTTPS_PROXY=http://127.0.0.1:2080
# HTTP_PROXY=http://127.0.0.1:2080
# NO_PROXY=localhost,127.0.0.1,*.local

# ---- Прочие переключатели ------------------------------------------------
# BUILD_DEB_NO_FILTER=1   # отключить grep-фильтр шумного вывода plugin-gtk
